# SMTP configuration for real email sending.
# Rename this file to .env.local and fill in the values below.

# SMTP Host (e.g., smtp.gmail.com for Gmail, smtp.sendgrid.net for SendGrid)
SMTP_HOST=smtp.gmail.com

# SMTP Port (commonly 587 for TLS, or 465 for SSL)
SMTP_PORT=587

# Set to true if port is 465 (SSL), false for other ports (TLS/unsecure)
SMTP_SECURE=false

# SMTP Username / Auth User (e.g., your-email@gmail.com)
SMTP_USER=your-email@gmail.com

# SMTP Password / Auth Password (for Gmail, generate a 16-character App Password)
SMTP_PASS=your-app-password

# Email Address to show in the "From" field of the email (must match auth username or be allowed by sender policy)
SMTP_FROM="Ananya Hi Solutions Careers" <your-email@gmail.com>
